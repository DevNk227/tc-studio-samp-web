generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ตารางข้อมูลผู้เล่น
model User {
  id           Int           @id @default(autoincrement())
  username     String        @unique
  password     String        // รหัสผ่านของเกม
  role         String        @default("user") // เอาไว้แยก admin กับ user ธรรมดา
  balance      Float         @default(0)
  createdAt    DateTime      @default(now())
  
  // เชื่อมความสัมพันธ์กับตารางแพ็กเกจ (1 ไอดี มี 1 แพ็กเกจที่ใช้งานอยู่)
  subscription Subscription? 
  topups       TopupHistory[]
  launcherConfig LauncherConfig?
  points   Int     @default(0)

}

// ตารางข้อมูลแพ็กเกจที่เปิดขายบนเว็บ
model Package {
  id           Int            @id @default(autoincrement())
  name         String         // ชื่อแพ็กเกจ เช่น VIP 30 Days
  price        Float          // ราคา
  durationDays Int            // จำนวนวัน
  
  subscriptions Subscription[]
}

// ตารางเก็บข้อมูลการเช่าแพ็กเกจ และเช็ค Device ID ของ Launcher
model Subscription {
  id          Int      @id @default(autoincrement())
  
  userId      Int      @unique
  user        User     @relation(fields: [userId], references: [id])
  
  packageId   Int
  package     Package  @relation(fields: [packageId], references: [id])
  
  hwid        String?  // เก็บ Device ID มือถือ (ตอนซื้อใหม่ๆ ให้เป็นค่าว่างไว้ก่อน)
  startDate   DateTime @default(now())
  expireDate  DateTime // วันหมดอายุ (เอาไว้ให้ API เช็ค)
}

model TopupHistory {
  id            Int      @id @default(autoincrement())
  userId        Int
  user          User     @relation(fields: [userId], references: [id])
  amount        Float    // จำนวนเงินที่เติม
  slipRef       String   @unique // รหัสอ้างอิงสลิป (สำคัญมาก! ใส่ @unique เพื่อให้ระบบกันสลิปซ้ำอัตโนมัติ)
  createdAt     DateTime @default(now())
}

// ตารางเก็บการตั้งค่า API Launcher ของลูกค้าแต่ละคน
model LauncherConfig {
  id                    Int      @id @default(autoincrement())
  userId                Int      @unique
  user                  User     @relation(fields: [userId], references: [id])
  clientVersionCode     Int      @default(1)
  clientSampVersionCode Int      @default(1)
  gameFilesVersionCode  Int      @default(1)
  urlGameFiles          String   @default("")
  urlGameFilesUpd       String   @default("")
  urlVk                 String   @default("")
  urlDiscord            String   @default("")
  urlYoutube            String   @default("")
  urlForum              String   @default("")
  urlDonate             String   @default("")
  urlClient             String   @default("")
  urlClientSampApk      String   @default("")

  serverIp              String   @default("127.0.0.1")
  serverPort            Int      @default(7777)
}

// เพิ่มตารางนี้ลงไปด้านล่างสุด
model RedeemCode {
  id          String   @id @default(cuid())
  code        String   @unique             // ชื่อโค้ด (เช่น "TCSTUDIO2026")
  points      Float                        // จำนวนพอยท์ที่ได้
  maxUses     Int      @default(1)         // จำนวนครั้งที่โค้ดนี้เติมได้ (เช่น แจก 100 คน)
  usedCount   Int      @default(0)         // จำนวนคนที่เติมไปแล้ว
  isActive    Boolean  @default(true)      // เปิด/ปิด การใช้งานโค้ดนี้
  createdAt   DateTime @default(now())
}

// ตารางสำหรับจำว่าใครเคยใช้โค้ดไหนไปแล้ว (กันคนกดซ้ำ)
model Redemption {
  id        String   @id @default(cuid())
  userId    Int   // รหัสผู้ใช้งาน (อ้างอิงจากตาราง User)
  codeId    String   // รหัสโค้ด (อ้างอิงจากตาราง RedeemCode)
  createdAt DateTime @default(now())

  // บังคับว่า 1 คน ใช้ 1 โค้ดได้แค่ครั้งเดียว
  @@unique([userId, codeId]) 
}